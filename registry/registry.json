{
  "repos": {
    "google-chrome": {
      "key_url": "https://dl.google.com/linux/linux_signing_key.pub",
      "repo_line": "deb [arch=amd64] http://dl.google.com/linux/chrome/deb/ stable main",
      "source_file": "/etc/apt/sources.list.d/google-chrome.list"
    }
  },

  "apps": {
    "chrome": {
      "type": "repo",
      "package": "google-chrome-stable",
      "repo": "google-chrome"
    },

    "vscode": {
      "type": "apt",
      "package": "code"
    },

    "htop": {
      "type": "apt",
      "package": "htop"
    },

    "git": {
      "type": "apt",
      "package": "git"
    },

    "nodejs": {
      "type": "apt",
      "package": "nodejs"
    },

    "npm": {
      "type": "apt",
      "package": "npm"
    },

    "mysql": {
      "type": "apt",
      "package": "mysql-server"
    },

    "ssh": {
      "type": "apt",
      "package": "openssh-server"
    },

    "vsftpd": {
      "type": "apt",
      "package": "vsftpd"
    },

    "filezilla-beta": {
      "type": "snap",
      "package": "filezilla"
    },

    "mysql-workbench": {
      "type": "snap",
      "package": "mysql-workbench-community"
    },

    "postman": {
      "type": "snap",
      "package": "postman"
    },

    "zyphor-cli": {
      "type": "apt",
      "package": "zyphor-cli"
    },

    "zyphor-wallpapers-default-2026-2027": {
      "type": "apt",
      "package": "zyphor-wallpapers-default-2026-2027"
    }
  },

  "php": {
    "8.4": {
      "packages": [
        "php8.4",
        "php8.4-cli",
        "php8.4-fpm",
        "php8.4-mysql",
        "php8.4-sqlite3",
        "php8.4-xml",
        "php8.4-mbstring",
        "php8.4-curl",
        "php8.4-zip",
        "php8.4-bcmath",
        "php8.4-intl",
        "php8.4-redis",
        "php8.4-gd",
        "libapache2-mod-php8.4"
      ]
    }
  }
}